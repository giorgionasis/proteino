NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI — preferred path (production + dev parity).
# All Gemini + Anthropic calls route through Vercel AI Gateway:
# unified observability, zero data retention, fallback routing.
# See vercel.com/docs/ai-gateway.
AI_GATEWAY_API_KEY=your-vercel-ai-gateway-key

# AI — local-dev fallback. When AI_GATEWAY_API_KEY is unset, the
# factory falls through to direct-Google calls via @ai-sdk/google.
# Conversational search fallback stays on Gemini (no Haiku splice).
GEMINI_API_KEY=your-google-ai-studio-key

# Google Books — optional but recommended for production. Without
# a key, requests fall back to unauthenticated mode with a stricter
# shared-IP quota and no observability. With a key: 1000/day per
# project + live metrics at console.cloud.google.com → Books API.
# Create at: console.cloud.google.com → Credentials → API key →
# restrict to "Books API".
GOOGLE_BOOKS_API_KEY=your-google-books-api-key

# Google Places (New) — venue enrichment for food + bars (and later
# hotels). Paid API: ~$32/1000 Text Search + ~$17/1000 Place Details.
# Set a budget alert at console.cloud.google.com → Billing.
# Create at: console.cloud.google.com → Credentials → API key →
# restrict to "Places API (New)" only.
GOOGLE_PLACES_API_KEY=your-google-places-api-key
