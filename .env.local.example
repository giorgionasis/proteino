NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI — preferred path (production + dev parity).
# All Gemini + Anthropic calls route through Vercel AI Gateway:
# unified observability, zero data retention, fallback routing.
# See vercel.com/docs/ai-gateway.
AI_GATEWAY_API_KEY=your-vercel-ai-gateway-key

# AI — local-dev fallback. When AI_GATEWAY_API_KEY is unset, the
# factory falls through to direct-Google calls via @ai-sdk/google.
# Conversational search fallback stays on Gemini (no Haiku splice).
GEMINI_API_KEY=your-google-ai-studio-key
